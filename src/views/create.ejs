<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create A User</title>
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body>
    <div class="topnav">
      <a href="/">Home</a>
      <a class="active" href="/create">Create User</a>
    </div>

    <div class="form-add-new">
      <form action="/create-user" method="post" enctype="multipart/form-data">
        <fieldset>
          <legend>Add New User</legend>

          <div class="input-group">
            <label>Email:</label>
            <input type="text" name="email" required />
          </div>
          <div class="input-group checkbox-group">
            <input
              type="checkbox"
              id="sendEmail"
              name="sendEmail"
              value="true"
            />
            <label for="sendEmail">Send welcome email</label>
          </div>
          <div class="input-group">
            <label>Name:</label>
            <input type="text" name="myname" required />
          </div>
          <div class="input-group">
            <label>City:</label>
            <input type="text" name="city" />
          </div>
          <div class="input-group">
            <label>Password:</label>
            <input type="password" name="password" required />
          </div>
          <div style="margin-bottom: 15px;">
    <label style="font-weight: bold;">Role:</label><br>
    <select name="role_id" style="width: 100%; padding: 8px; margin-top: 5px; background: #2b2b2b; color: white; border: 1px solid #444; border-radius: 4px;">
        <option value="">-- Chọn Role --</option>
        
        <% if (listRoles && listRoles.length > 0) { %>
            <% listRoles.forEach(function(role) { %>
                <option value="<%= role.id %>">
                    <%= role.role_name %>
                </option>
            <% }) %>
        <% } %>
        
    </select>
</div>
          <div class="input-group">
            <label>Avatar:</label>
            <input type="file" name="avatar" />
          </div>

          <button type="submit">Save User</button>
        </fieldset>
      </form>
    </div>
  </body>
</html>
