<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Home Page</title>
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body>
    <% 
      let privileges = (user && user.privileges) ? user.privileges : [];
      let canAdd = privileges.includes('ADD_USER');
      let canUpdate = privileges.includes('UPDATE_USER');
      let canDelete = privileges.includes('DELETE_USER');
      
      // Nếu có quyền Sửa HOẶC Xóa thì mới được xem cột Action
      let canViewActions = canUpdate || canDelete; 
    %>

    <div class="topnav">
      <a class="active" href="/">Home</a>
      
      <% if(user){ %>
        <% if(canAdd){ %>
          <a href="/create">Create User</a>
        <% } %>

        <% if(canDelete){ %>
          <a href="/roles" style="color: #ffeb3b; font-weight: bold;">⚙️ Manage Roles</a>
        <% } %>

        <a href="/logout">Logout</a>
      <% } else { %>
        <a href="/login">Login</a>
      <% } %>
    </div>

    <div class="table-container">
      <div class="title">List Users</div>
      <div class="table-wrapper">
        <table>
          <tr>
            <th>ID</th>
            <th>Email</th>
            <th>Name</th>
            <th>City</th>
            <th>Avatar</th>
            <% if(canViewActions){ %>
              <th>Action</th>
            <% } %>
          </tr>

          <% listUsers.forEach(function(item) { %>
          <tr>
            <td><%= item.id %></td>
            <td><%= item.email %></td>
            <td><%= item.name %></td>
            <td><%= item.city %></td>
            <td>
              <img src="<%= item.avatar %>" class="avatar-img" alt="Avatar" />
            </td>
            
            <% if(canViewActions){ %>
            <td>
              <div class="action-buttons">
                <% if(canUpdate){ %>
                  <a href="/update/<%= item.id %>">
                    <button class="btn-small">Edit</button>
                  </a>
                <% } %>

                <% if(canDelete){ %>
                  <form action="/delete-user/<%= item.id %>" method="post" style="display:inline;">
                    <button class="btn-small btn-danger">Delete</button>
                  </form>
                <% } %>
              </div>
            </td>
            <% } %>
          </tr>
          <% }) %>
        </table>
      </div>
    </div>
  </body>
</html>