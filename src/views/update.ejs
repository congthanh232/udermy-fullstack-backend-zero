<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Update A User</title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>

  <body>
    <div class="topnav">
      <a href="/">Home</a>
      <a href="/create">Create User</a>
    </div>
    <div class="form-add-new">
      <form action="/update-user" method="post" enctype="multipart/form-data">
        <fieldset>
          <legend>Update a users</legend>
          <div class="input-group d-none">
            <label>Id:</label>
            <input type="text" name="userId" value="<%= userEdit.id %>" />
          </div>

          <div class="input-group">
            <label>Email:</label>
            <input type="text" name="email" value="<%= userEdit.email %>" />
          </div>
          <div class="input-group">
            <label>Name:</label>
            <input type="text" name="myname" value="<%= userEdit.name %>" />
          </div>
          <div class="input-group">
            <label>City:</label>
            <input type="text" name="city" value="<%= userEdit.city %>" />
          </div>
          <div class="input-group">
            <label>Password:</label>
            <input type="text" name="password" value="<%= userEdit.password %>" />
          </div>
          <div>
            <label>Role:</label>
  <select name="role">
    <option value="user" <%= userEdit.role === 'user' ? 'selected' : '' %>>User</option>
    <option value="admin" <%= userEdit.role === 'admin' ? 'selected' : '' %>>Admin</option>
  </select>
          </div>
          <div>
            <!-- HIỂN THỊ AVATAR -->
  <% if (userEdit.avatar) { %>
    <img src="<%= userEdit.avatar %>" width="120" />
  <% } %>

  <br>

  <!-- CHỌN ẢNH MỚI -->
  Change Avatar:
  <input type="file" name="avatar" />
          </div>
          <div>
            <button>Save</button>
          </div>
        </fieldset>
      </form>
    </div>
  </body>
</html>
